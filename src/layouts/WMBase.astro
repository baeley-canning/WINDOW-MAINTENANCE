---
import "../styles/global.css";
import StickyBar from "../components/StickyBar.astro";
const {
  title,
  description,
  canonical,
  ogImage = "/img/og-cover.jpg",
  schema,
  noindex = false,
  showHeader = true,
  showFooter = true,
  showStickyBar = true
} = Astro.props;h
const siteName = "Window Maintenance";
const schemas = Array.isArray(schema) ? schema : (schema ? [schema] : []);
const baseSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: siteName,
  url: "https://windowmaintenance.co.nz",
  telephone: "+6421638205",
  email: "baeley@windowmaintenance.co.nz",
  sameAs: ["https://www.facebook.com/WindowMaintenanceNZ/"],
  image: "/img/og-cover.jpg",
  address: { "@type": "PostalAddress", addressLocality: "Wellington", addressRegion: "WGN", addressCountry: "NZ" },
};
const providedTypes = new Set(schemas.map((s:any) => s && s["@type"]).filter(Boolean));
const allSchemas = providedTypes.has("LocalBusiness") ? schemas : [...schemas, baseSchema];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/fonts/inter/inter-latin-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter/inter-latin-700.woff2" as="font" type="font/woff2" crossorigin />
    <meta name="msapplication-TileColor" content="#2563eb" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)}></script>
    ))}
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-69S1NYW3V6"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
      window.gtag("js", new Date());
      window.gtag("config", "G-69S1NYW3V6");
      window.gtag("config", "AW-16889477810");

      window.gtag_report_conversion = function (url) {
        var callback = function () {
          if (typeof url !== "undefined") {
            window.location = url;
          }
        };
        window.gtag("event", "conversion", {
          send_to: "AW-16889477810/q6GQCNa6kfMbELL1w_U-",
          value: 1.0,
          currency: "NZD",
          event_callback: callback
        });
        return false;
      };

      window.gtag_report_form_conversion = function (form) {
        try {
          var emailInput = form && form.querySelector && form.querySelector('input[name="email"]');
          var phoneInput = form && form.querySelector && form.querySelector('input[name="phone"]');
          var email = emailInput && emailInput.value ? emailInput.value.trim() : "";
          var phone = phoneInput && phoneInput.value ? phoneInput.value.trim() : "";
          if (email || phone) {
            window.gtag("set", "user_data", {
              email: email || undefined,
              phone_number: phone || undefined
            });
          }
        } catch (_) {}
        return window.gtag_report_conversion();
      };
    </script>
    <script src="https://analytics.ahrefs.com/analytics.js" data-key="1qYp7UMQiOWTjRN9OG1kOQ" async></script>
  </head>
  <body class="min-h-screen selection:bg-blue-600/30 bg-[var(--brand-bg)] text-[var(--brand-text)]">
    {showHeader && (
      <header class="sticky top-0 z-30 border-b bg-[var(--brand-bg)]/80 backdrop-blur-md border-[color:var(--brand-border)]">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
          <a href="/" class="flex items-center gap-2.5 font-extrabold tracking-tight text-slate-900">
            <svg class="h-6 w-6 flex-shrink-0 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="2.5"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <line x1="12" y1="2" x2="12" y2="12"/>
            </svg>
            <span>Window Maintenance</span>
          </a>
          <nav class="hidden gap-1 md:flex">
            <a href="/services/" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100 hover:text-blue-600">Services</a>
            <a href="/areas/" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100 hover:text-blue-600">Areas</a>
            <a href="/gallery/" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100 hover:text-blue-600">Gallery</a>
            <a href="/blog/" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100 hover:text-blue-600">Blog</a>
            <a href="/reviews/" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100 hover:text-blue-600">Reviews</a>
            <a href="/contact/" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100 hover:text-blue-600">Contact</a>
          </nav>
          <div class="flex items-center gap-2">
            <a
              href="tel:+6421638205"
              aria-label="Call 021 638 205"
              data-cta="call"
              class="btn btn-primary px-3 py-2.5 md:hidden">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.72A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            </a>
            <a
              href="tel:+6421638205"
              id="cta-call-header"
              data-cta="call"
              class="btn btn-primary text-sm px-5 py-2.5 hidden md:inline-flex"
              >Call 021 638 205</a>
            <button
              id="mobile-menu-toggle"
              type="button"
              aria-label="Open menu"
              aria-expanded="false"
              aria-controls="mobile-menu"
              class="inline-flex items-center justify-center rounded-lg p-2 text-slate-800 ring-1 ring-slate-200 transition hover:bg-slate-100 md:hidden">
              <svg id="mobile-menu-icon-open" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
              <svg id="mobile-menu-icon-close" class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
        </div>
        <nav id="mobile-menu" aria-label="Mobile navigation" class="hidden border-t border-[color:var(--brand-border)] md:hidden">
          <div class="mx-auto flex max-w-6xl flex-col gap-1 px-6 py-3">
            <a href="/services/" class="rounded-lg px-3 py-2.5 text-sm font-medium text-slate-800 transition-colors hover:bg-slate-100 hover:text-blue-600">Services</a>
            <a href="/areas/" class="rounded-lg px-3 py-2.5 text-sm font-medium text-slate-800 transition-colors hover:bg-slate-100 hover:text-blue-600">Areas</a>
            <a href="/gallery/" class="rounded-lg px-3 py-2.5 text-sm font-medium text-slate-800 transition-colors hover:bg-slate-100 hover:text-blue-600">Gallery</a>
            <a href="/blog/" class="rounded-lg px-3 py-2.5 text-sm font-medium text-slate-800 transition-colors hover:bg-slate-100 hover:text-blue-600">Blog</a>
            <a href="/reviews/" class="rounded-lg px-3 py-2.5 text-sm font-medium text-slate-800 transition-colors hover:bg-slate-100 hover:text-blue-600">Reviews</a>
            <a href="/contact/" class="rounded-lg px-3 py-2.5 text-sm font-medium text-slate-800 transition-colors hover:bg-slate-100 hover:text-blue-600">Contact</a>
            <a href="tel:+6421638205" data-cta="call" class="btn btn-primary mt-2">Call 021 638 205</a>
          </div>
        </nav>
      </header>
    )}
    <main><slot /></main>
    {showFooter && (
      <footer class="mt-20 border-t bg-[var(--brand-surface)] border-[color:var(--brand-border)]">
        <div class="mx-auto max-w-6xl px-6 py-12">
          <div class="grid gap-10 md:grid-cols-3">
            <div>
              <div class="flex items-center gap-2 font-bold text-slate-900">
                <svg class="h-5 w-5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="2.5"/>
                  <line x1="2" y1="12" x2="22" y2="12"/>
                  <line x1="12" y1="2" x2="12" y2="12"/>
                </svg>
                Window Maintenance
              </div>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">
                Aluminium window &amp; sliding door repairs across the Wellington region.
              </p>
              <a href="tel:+6421638205" data-cta="call" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-blue-600/10 px-4 py-2.5 text-sm font-semibold text-blue-600 ring-1 ring-blue-600/20 transition hover:bg-blue-600/20">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.72A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                021 638 205
              </a>
            </div>
            <div class="text-sm">
              <div class="mb-3 font-semibold text-slate-900">Contact</div>
              <ul class="space-y-2 text-slate-600">
                <li><a class="transition hover:text-blue-600" href="tel:+6421638205">021 638 205</a></li>
                <li><a class="transition hover:text-blue-600" href="mailto:baeley@windowmaintenance.co.nz">baeley@windowmaintenance.co.nz</a></li>
                <li><a class="transition hover:text-blue-600" href="https://www.facebook.com/WindowMaintenanceNZ/">Facebook</a></li>
                <li>Wellington region</li>
                <li>NZBN: 9429052805455</li>
              </ul>
            </div>
            <div class="text-sm">
              <div class="mb-3 font-semibold text-slate-900">Areas</div>
              <ul class="space-y-2 text-slate-600">
                <li><a class="transition hover:text-blue-600" href="/areas/central-wellington/">Central Wellington</a></li>
                <li><a class="transition hover:text-blue-600" href="/areas/porirua/">Porirua</a></li>
                <li><a class="transition hover:text-blue-600" href="/areas/lower-hutt/">Lower Hutt</a></li>
                <li><a class="transition hover:text-blue-600" href="/areas/upper-hutt/">Upper Hutt</a></li>
                <li><a class="transition hover:text-blue-600" href="/areas/petone/">Petone</a></li>
                <li><a class="transition hover:text-blue-600" href="/areas/kapiti/">Kāpiti</a></li>
              </ul>
            </div>
          </div>
        </div>
        <div class="border-t border-slate-200 py-4 text-center text-xs text-slate-500">
          &copy; {new Date().getFullYear()} Window Maintenance &mdash; Wellington, NZ &mdash;
          <a class="hover:text-blue-600 transition" href="/privacy/">Privacy Policy</a> &mdash;
          Site by <a class="hover:text-blue-600 transition" href="https://slateseo.co.nz">SlateSEO</a>
        </div>
      </footer>
    )}
    {showStickyBar && <StickyBar />}
    <script>
      // Mobile menu toggle
      (function(){
        try {
          var btn = document.getElementById('mobile-menu-toggle');
          var menu = document.getElementById('mobile-menu');
          var iconOpen = document.getElementById('mobile-menu-icon-open');
          var iconClose = document.getElementById('mobile-menu-icon-close');
          if (!btn || !menu) return;
          btn.addEventListener('click', function(){
            var open = !menu.classList.toggle('hidden');
            btn.setAttribute('aria-expanded', open ? 'true' : 'false');
            btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
            if (iconOpen) iconOpen.classList.toggle('hidden', open);
            if (iconClose) iconClose.classList.toggle('hidden', !open);
          });
        } catch(_) {}
      })();
    </script>
    <script>
  // Track call clicks + fire Google Ads conversion (AW-16889477810)
  (function(){
    try {
      document.addEventListener('click', function(e){
        var a = e.target && (e.target.closest && e.target.closest('a[data-cta="call"]'));
        if (!a) return;
        // Push to dataLayer for GA4
        if (window && window.dataLayer) {
          window.dataLayer.push({ event: 'call_click', href: a.getAttribute('href'), id: a.id || null, path: location.pathname });
        }
        // Fire Google Ads phone call conversion
        if (window.gtag) {
          window.gtag('event', 'conversion', {
            'send_to': 'AW-16889477810/msZ6CJqJhcgcELl1w_U-',
            'value': 10.0,
            'currency': 'NZD'
          });
        }
      }, true);
    } catch(_) {}
  })();
/script>
    <script>
      (function () {
        try {
          var storageKey = "wmLeadRecentSubmission";
          var recentWindowMs = 1000 * 60 * 60 * 12;
          var readRecentSubmission = function () {
            try {
              var raw = window.localStorage.getItem(storageKey);
              return raw ? JSON.parse(raw) : null;
            } catch (_) {
              return null;
            }
          };

          var hasRecentSubmission = function () {
            var recent = readRecentSubmission();
            return !!(recent && recent.ts && (Date.now() - recent.ts) < recentWindowMs);
          };

          document.querySelectorAll("form[data-lead-form]").forEach(function (form) {
            if (form.dataset.leadFormReady === "1") return;
            form.dataset.leadFormReady = "1";

            var submitButton = form.querySelector("[data-submit-button]");
            var pendingNotice = form.querySelector("[data-form-pending]");
            var recentNotice = form.querySelector("[data-form-recent]");
            var actionRow = form.querySelector("[data-form-actions]");

            if (hasRecentSubmission() && recentNotice) {
              recentNotice.classList.remove("hidden");
            }

            form.addEventListener("submit", function (event) {
              if (form.dataset.submitting === "1") {
                event.preventDefault();
                return false;
              }

              form.dataset.submitting = "1";

              if (recentNotice) {
                recentNotice.classList.add("hidden");
              }

              if (pendingNotice) {
                pendingNotice.classList.remove("hidden");
                pendingNotice.scrollIntoView({ behavior: "smooth", block: "center" });
              }

              if (submitButton) {
                submitButton.disabled = true;
                submitButton.setAttribute("aria-disabled", "true");
                submitButton.textContent = "Sending...";
              }

              if (actionRow) {
                actionRow.classList.add("pointer-events-none", "opacity-60");
              }
            });
          });
        } catch (_) {}
      })();
    </script>
  </body>
  
</html>
