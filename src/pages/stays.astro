---
import Layout from "../layouts/WMBase.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Picture from "../components/Picture.astro";
import QuoteInline from "../components/QuoteInline.astro";
import FAQ from "../components/FAQ.astro";

const title = "Awning Stays, Window Hinges & Restrictors Wellington";
const description = "Awning stay replacement, window hinge service, restrictors and security stays fitted across Wellington for aluminium windows that no longer open, hold or seal properly.";
const canonical = "https://windowmaintenance.co.nz/stays/";

const faqItems = [
  {
    q: "Do you replace bent awning stays after storms?",
    a: "Yes. We replace bent awning stays, re-align the sash and make sure the window opens, holds position and seals properly again."
  },
  {
    q: "Are awning stays the same as window hinges?",
    a: "Many people call them window hinges, but awning stays are the support arms that control the opening. We service both stays and hinges as part of the same repair."
  },
  {
    q: "Can you fit hidden in-frame security stays?",
    a: "Yes. Where the profile allows, we fit in-frame security stays for a cleaner look and less visible fixing points than face-mounted hardware."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a
    }
  }))
};
---

<Layout title={title} description={description} canonical={canonical} schema={[faqSchema]}>
  <Breadcrumbs />

  <main class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="text-3xl font-extrabold">Awning Stays, Hinges & Restrictors</h1>
    <p class="mt-4 text-slate-300">This page is for awning stay replacement, window hinge service, restrictors and in-frame security stays across Wellington. If the sash will not stay open, has been bent in bad weather, is dropping out of alignment or needs a cleaner security-stay setup, this is the right page.</p>

    <section class="mt-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">Common issues</h2>
        <p class="mt-2 text-sm text-slate-300">Bent awning stays, seized hinges, loose restrictors, sash movement, poor closing pressure and windows that no longer hold position safely.</p>
      </div>
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">What we do</h2>
        <p class="mt-2 text-sm text-slate-300">We replace failed stays, service hinges, fit restrictors and security stays and then re-align the sash so the window seals and operates properly.</p>
      </div>
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">What happens next</h2>
        <p class="mt-2 text-sm text-slate-300">A photo of the stay, hinge or bent sash helps. We can usually tell quickly whether it is a straight replacement, a hinge service or a wider alignment issue.</p>
      </div>
    </section>

    <section class="mt-8 rounded-2xl bg-[var(--brand-surface)] p-6 ring-1 ring-white/10">
      <h2 class="text-2xl font-bold">Searches we commonly help with</h2>
      <p class="mt-3 text-slate-300">This page supports searches like window stay replacement, awning stay replacement, window hinge repair, awning window hinge repair, security stays Wellington, hidden security stays and window restrictor fitting. Many people search for hinges when the actual failed part is the awning stay, so this page covers both.</p>
      <div class="mt-4 flex flex-wrap gap-3 text-sm">
        <a class="rounded-full border border-white/10 px-3 py-2 text-slate-200 hover:border-amber-400 hover:text-amber-300" href="/security/">Security stays</a>
        <a class="rounded-full border border-white/10 px-3 py-2 text-slate-200 hover:border-amber-400 hover:text-amber-300" href="/services/window-repairs/">Window repairs</a>
        <a class="rounded-full border border-white/10 px-3 py-2 text-slate-200 hover:border-amber-400 hover:text-amber-300" href="/services/hardware-wedge-replacement/">Handles, locks and restrictors</a>
      </div>
    </section>

    <QuoteInline
      title="Get a quote for stays, hinges or restrictors"
      subtitle="Best for bent awning stays, failed hinges, in-frame security stays, restrictors and windows that no longer hold position."
      buttonLabel="Get my stays quote"
      source="stays_page"
    />

    <section class="mt-10 grid gap-4 sm:grid-cols-2">
      <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
        <div class="ratio-4-3 card-frame">
          <Picture base="hinge" alt="Window hinge replacement and sash realignment" className="h-full w-full object-cover" />
        </div>
        <figcaption class="mt-2 text-sm text-slate-400">Hinge service and sash alignment often need to happen alongside awning stay replacement.</figcaption>
      </figure>
      <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
        <div class="ratio-4-3 card-frame">
          <Picture base="security-stays" alt="Window security stays and restrictors fitted to aluminium joinery" className="h-full w-full object-cover" />
        </div>
        <figcaption class="mt-2 text-sm text-slate-400">We fit restrictors and hidden security stays where the joinery profile allows it.</figcaption>
      </figure>
    </section>

    <figure class="mt-6 rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
      <img src="/img/window-stay-replacement-640.webp" alt="New awning stay installed after storm damage in Wellington" class="w-full rounded-xl object-cover" width="640" height="853" loading="lazy" decoding="async" />
      <figcaption class="mt-2 text-sm text-slate-400">Storm-damaged awning stay removed, new stay fitted and sash brought back into line. <a class="text-amber-400 underline" href="/blog/awning-stay-repair-storm/">Read the job recap.</a></figcaption>
    </figure>

    <section class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Where we work</h2>
      <p class="text-slate-300">We replace stays and service hinges across <a class="text-amber-400 underline" href="/areas/central-wellington/">Central Wellington</a>, <a class="text-amber-400 underline" href="/areas/porirua/">Porirua</a>, <a class="text-amber-400 underline" href="/areas/lower-hutt/">Lower Hutt</a>, <a class="text-amber-400 underline" href="/areas/upper-hutt/">Upper Hutt</a>, <a class="text-amber-400 underline" href="/areas/petone/">Petone</a> and <a class="text-amber-400 underline" href="/areas/kapiti/">Kapiti</a>.</p>
      <p class="text-slate-300">Related pages: <a class="text-amber-400 underline" href="/security/">Security stays</a> • <a class="text-amber-400 underline" href="/services/window-repairs/">Window repairs</a> • <a class="text-amber-400 underline" href="/services/joinery-repairs/">Aluminium joinery repairs</a></p>
    </section>

    <section class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Helpful guides</h2>
      <ul class="list-disc space-y-2 pl-5 text-slate-300">
        <li><a class="text-amber-400 underline" href="/blog/awning-stay-repair-storm/">Awning stay replacement after a storm</a></li>
        <li><a class="text-amber-400 underline" href="/blog/window-stays-replacement-guide/">Do your window stays need replacing?</a></li>
        <li><a class="text-amber-400 underline" href="/blog/inframe-security-stays-wellington/">In-frame security stays vs face-mounted stays</a></li>
      </ul>
    </section>
  </main>

  <FAQ heading="Stays and hinges FAQs" items={faqItems} />
</Layout>
