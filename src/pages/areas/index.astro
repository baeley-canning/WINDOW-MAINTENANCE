---
import Layout from "../../layouts/WMBase.astro"; import Breadcrumbs from "../../components/Breadcrumbs.astro";
const title = "Service Areas | Wellington window & sliding door repairs"; const description = "Single and double-glazed aluminium window and sliding door repairs across Central Wellington, Porirua, Lower Hutt, Upper Hutt, Petone and Kāpiti.";
const canonical = "https://windowmaintenance.co.nz/areas/";
---
<Layout title={title} description={description} canonical={canonical}>
  <Breadcrumbs />
  <section class="mx-auto max-w-6xl px-6 py-12">
    <h1 class="text-3xl font-extrabold">Service Areas</h1>
    <p class="mt-3 text-slate-700">We’re Wellington-based and on the road daily across Porirua, Lower Hutt, Upper Hutt, Petone and Kāpiti. Same-week bookings whenever possible.</p>
    <div class="mt-8 grid gap-5 sm:grid-cols-2 md:grid-cols-3">
      <a class="card-link rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-slate-200" href="/areas/central-wellington/">
        <div class="font-semibold text-slate-900">Central Wellington</div>
        <p class="mt-1 text-sm text-slate-600">City apartments, rental repairs and hillside joinery.</p>
      </a>
      <a class="card-link rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-slate-200" href="/areas/porirua/">
        <div class="font-semibold text-slate-900">Porirua</div>
        <p class="mt-1 text-sm text-slate-600">Coastal salt-air hardware, ranchsliders and sill leaks.</p>
      </a>
      <a class="card-link rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-slate-200" href="/areas/lower-hutt/">
        <div class="font-semibold text-slate-900">Lower Hutt</div>
        <p class="mt-1 text-sm text-slate-600">Rollers, window handles and leak repairs across the Hutt.</p>
      </a>
      <a class="card-link rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-slate-200" href="/areas/upper-hutt/">
        <div class="font-semibold text-slate-900">Upper Hutt</div>
        <p class="mt-1 text-sm text-slate-600">Window stays, locks and draught fixes for family homes.</p>
      </a>
      <a class="card-link rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-slate-200" href="/areas/petone/">
        <div class="font-semibold text-slate-900">Petone</div>
        <p class="mt-1 text-sm text-slate-600">Salt-air hardware, seized locks and rattling windows.</p>
      </a>
      <a class="card-link rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-slate-200" href="/areas/kapiti/">
        <div class="font-semibold text-slate-900">Kāpiti</div>
        <p class="mt-1 text-sm text-slate-600">Ranchsliders, window repairs, lockouts and reseals.</p>
      </a>
    </div>
  </section>
</Layout>
