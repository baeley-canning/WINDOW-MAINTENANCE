---
import Layout from "../layouts/WMBase.astro";

const title = "Job Portal | Window Maintenance";
const description = "Private job calendar and schedule portal for Window Maintenance.";
const canonical = "https://windowmaintenance.co.nz/portal/";
---

<Layout title={title} description={description} canonical={canonical} noindex={true}>
  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10">
    <div id="portal-login" class="mx-auto max-w-md rounded-2xl bg-[var(--brand-surface)] p-6 ring-1 ring-white/10">
      <h1 class="text-2xl font-extrabold">Job Portal Login</h1>
      <p class="mt-2 text-sm text-slate-300">Private scheduling portal for day-to-day bookings.</p>
      <form id="login-form" class="mt-5 space-y-4">
        <label class="block">
          <span class="text-sm">Username</span>
          <input id="login-user" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" autocomplete="username" required />
        </label>
        <label class="block">
          <span class="text-sm">Password</span>
          <input id="login-pass" type="password" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" autocomplete="current-password" required />
        </label>
        <p id="login-error" class="hidden text-sm text-red-300">Incorrect username or password.</p>
        <button class="btn btn-primary w-full" type="submit">Sign in</button>
      </form>
    </div>

    <div id="portal-app" class="hidden">
      <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
        <div>
          <h1 class="text-2xl font-extrabold sm:text-3xl">Job Calendar Portal</h1>
          <p class="mt-1 text-sm text-slate-300">Add jobs, view daily run sheets, call customers, and open maps in one tap.</p>
          <p id="portal-status" class="mt-1 text-xs text-slate-400">Connecting to portal...</p>
        </div>
        <div class="flex items-center gap-2">
          <button id="today-btn" class="btn btn-outline px-4 py-2 text-sm">Today</button>
          <button id="refresh-btn" class="btn btn-outline px-4 py-2 text-sm">Refresh</button>
          <button id="logout-btn" class="btn btn-secondary px-4 py-2 text-sm">Logout</button>
        </div>
      </div>

      <div class="grid gap-4 lg:grid-cols-3">
        <div class="space-y-4 lg:col-span-2">
          <div class="rounded-2xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10 sm:p-5">
            <div class="mb-4 flex items-center justify-between">
              <button id="month-prev" class="btn btn-outline px-3 py-2 text-sm" type="button">&larr; Prev</button>
              <h2 id="month-label" class="text-lg font-bold"></h2>
              <button id="month-next" class="btn btn-outline px-3 py-2 text-sm" type="button">Next &rarr;</button>
            </div>
            <div class="grid grid-cols-7 gap-1 text-center text-xs uppercase tracking-wide text-slate-400 sm:gap-2">
              <div>Sun</div><div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div>
            </div>
            <div id="calendar-grid" class="mt-2 grid grid-cols-7 gap-1 sm:gap-2"></div>
          </div>

          <div class="rounded-2xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10 sm:p-5">
            <div class="mb-3 flex items-center justify-between">
              <h2 id="day-title" class="text-lg font-bold">Jobs</h2>
              <span id="day-count" class="rounded-full bg-white/10 px-3 py-1 text-xs text-slate-300">0 jobs</span>
            </div>
            <div id="job-list" class="space-y-3"></div>
            <p id="job-empty" class="text-sm text-slate-400">No jobs for this day.</p>
          </div>

          <div class="rounded-2xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10 sm:p-5">
            <div class="mb-3 flex items-center justify-between">
              <h2 class="text-lg font-bold">Job Heatmap</h2>
              <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-slate-300">Area load</span>
            </div>
            <p class="text-sm text-slate-300">Filter by month and day to see where your jobs are clustered.</p>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              <label class="block">
                <span class="text-xs text-slate-400">Month</span>
                <input id="heatmap-month" type="month" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" />
              </label>
              <label class="block">
                <span class="text-xs text-slate-400">Day</span>
                <select id="heatmap-day" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10"></select>
              </label>
            </div>
            <p id="heatmap-summary" class="mt-3 text-sm text-slate-300">No jobs loaded.</p>
            <div class="mt-2 flex flex-wrap items-center gap-2">
              <code id="heatmap-line" class="rounded bg-[var(--brand-bg)] px-2 py-1 text-xs text-amber-300">I am in Wellington today.</code>
              <button id="heatmap-copy-line" type="button" class="btn btn-outline px-2 py-1 text-xs">Copy line</button>
            </div>
            <div id="heatmap-grid" class="mt-3 grid gap-2 sm:grid-cols-2"></div>
          </div>
        </div>

        <div class="rounded-2xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10 sm:p-5">
          <h2 id="form-title" class="text-lg font-bold">Add Job</h2>
          <form id="job-form" class="mt-4 space-y-3">
            <label class="block">
              <span class="text-sm">Date</span>
              <input id="job-date" type="date" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" required />
            </label>
            <label class="block">
              <span class="text-sm">Time</span>
              <input id="job-time" type="time" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" required />
            </label>
            <label class="block">
              <span class="text-sm">Customer name</span>
              <input id="job-customer" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" required />
            </label>
            <label class="block">
              <span class="text-sm">Phone number</span>
              <input id="job-phone" type="tel" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" required />
            </label>
            <label class="block">
              <span class="text-sm">Address</span>
              <input id="job-address" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" required />
            </label>
            <label class="block">
              <span class="text-sm">Short job description</span>
              <textarea id="job-summary" rows="3" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" required></textarea>
            </label>
            <label class="block">
              <span class="text-sm">Status</span>
              <select id="job-status" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10">
                <option value="Booked">Booked</option>
                <option value="In progress">In progress</option>
                <option value="Done">Done</option>
              </select>
            </label>
            <div class="flex flex-wrap gap-2 pt-1">
              <button id="job-save" class="btn btn-primary flex-1" type="submit">Save job</button>
              <button id="job-clear" class="btn btn-outline" type="button">Clear</button>
            </div>
          </form>
          <p class="mt-3 text-xs text-slate-400">Tip: tap customer phone to call, or address to open Google Maps.</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const API_BASE = "/api/portal/";

      const el = {
        loginWrap: document.getElementById("portal-login"),
        appWrap: document.getElementById("portal-app"),
        loginForm: document.getElementById("login-form"),
        loginUser: document.getElementById("login-user"),
        loginPass: document.getElementById("login-pass"),
        loginError: document.getElementById("login-error"),
        logoutBtn: document.getElementById("logout-btn"),
        refreshBtn: document.getElementById("refresh-btn"),
        todayBtn: document.getElementById("today-btn"),
        monthPrev: document.getElementById("month-prev"),
        monthNext: document.getElementById("month-next"),
        monthLabel: document.getElementById("month-label"),
        calendarGrid: document.getElementById("calendar-grid"),
        dayTitle: document.getElementById("day-title"),
        dayCount: document.getElementById("day-count"),
        jobList: document.getElementById("job-list"),
        jobEmpty: document.getElementById("job-empty"),
        portalStatus: document.getElementById("portal-status"),
        jobForm: document.getElementById("job-form"),
        formTitle: document.getElementById("form-title"),
        inputDate: document.getElementById("job-date"),
        inputTime: document.getElementById("job-time"),
        inputCustomer: document.getElementById("job-customer"),
        inputPhone: document.getElementById("job-phone"),
        inputAddress: document.getElementById("job-address"),
        inputSummary: document.getElementById("job-summary"),
        inputStatus: document.getElementById("job-status"),
        jobClear: document.getElementById("job-clear"),
        heatmapMonth: document.getElementById("heatmap-month"),
        heatmapDay: document.getElementById("heatmap-day"),
        heatmapSummary: document.getElementById("heatmap-summary"),
        heatmapLine: document.getElementById("heatmap-line"),
        heatmapCopyLine: document.getElementById("heatmap-copy-line"),
        heatmapGrid: document.getElementById("heatmap-grid")
      };

      const today = new Date();
      const state = {
        jobs: [],
        selectedDate: dateKey(today),
        month: new Date(today.getFullYear(), today.getMonth(), 1),
        heatmapMonth: dateKey(today).slice(0, 7),
        heatmapDay: String(today.getDate()).padStart(2, "0"),
        editId: null,
        pollTimer: null,
        saveInFlight: false
      };

      const AREA_KEYWORDS = [
        { area: "Wellington South", terms: ["wellington south", "newtown", "berhampore", "island bay", "lyall bay", "brooklyn", "kilbirnie", "miramar", "seatoun", "strathmore"] },
        { area: "Wellington Central", terms: ["wellington central", "te aro", "thorndon", "wadestown", "kelburn", "oriental bay", "mount victoria", "mt victoria", "newlands", "karori"] },
        { area: "Wellington North", terms: ["wellington north", "johnsonville", "churton park", "tawa", "ngaio", "khandallah", "paparangi", "crofton downs"] },
        { area: "Lower Hutt", terms: ["lower hutt", "petone", "woburn", "waterloo", "naenae", "taita", "eastbourne", "seaview", "moera", "wellington hutt"] },
        { area: "Upper Hutt", terms: ["upper hutt", "trentham", "silverstream", "heretaunga", "totara park", "akatarawa"] },
        { area: "Porirua", terms: ["porirua", "aotea", "papakowhai", "titahi bay", "cannons creek", "plimmerton", "pukerua bay"] },
        { area: "Kapiti Coast", terms: ["kapiti", "kapiti coast", "paraparaumu", "raumati", "waikanae", "otaki", "paekakariki"] }
      ];

      const AREA_ORDER = AREA_KEYWORDS.map(function (x) { return x.area; }).concat(["Other"]);

      function dateKey(d) {
        const y = d.getFullYear();
        const m = String(d.getMonth() + 1).padStart(2, "0");
        const day = String(d.getDate()).padStart(2, "0");
        return y + "-" + m + "-" + day;
      }

      function parseDate(str) {
        const parts = String(str || "").split("-");
        if (parts.length !== 3) return new Date();
        return new Date(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]));
      }

      function formatLongDate(str) {
        const d = parseDate(str);
        return d.toLocaleDateString("en-NZ", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
      }

      function formatMonthLabel(value) {
        const parts = String(value || "").split("-");
        if (parts.length !== 2) return "selected month";
        const d = new Date(Number(parts[0]), Number(parts[1]) - 1, 1);
        return d.toLocaleDateString("en-NZ", { month: "long", year: "numeric" });
      }

      function daysInMonth(value) {
        const parts = String(value || "").split("-");
        if (parts.length !== 2) return 31;
        const year = Number(parts[0]);
        const month = Number(parts[1]);
        if (!year || !month) return 31;
        return new Date(year, month, 0).getDate();
      }

      function safeText(v) {
        return String(v || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/\"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function setPortalStatus(message, isError) {
        el.portalStatus.textContent = message;
        el.portalStatus.classList.toggle("text-red-300", Boolean(isError));
        el.portalStatus.classList.toggle("text-slate-400", !isError);
      }

      function showLogin() {
        el.loginWrap.classList.remove("hidden");
        el.appWrap.classList.add("hidden");
        stopPolling();
      }

      function showApp() {
        el.loginWrap.classList.add("hidden");
        el.appWrap.classList.remove("hidden");
      }

      function clearLoginError() {
        el.loginError.textContent = "Incorrect username or password.";
        el.loginError.classList.add("hidden");
      }

      function showLoginError(message) {
        el.loginError.textContent = message;
        el.loginError.classList.remove("hidden");
      }

      async function apiRequest(endpoint, options) {
        const opts = options || {};
        const init = {
          method: opts.method || "GET",
          credentials: "same-origin",
          headers: { Accept: "application/json" }
        };

        if (opts.body !== undefined) {
          init.headers["Content-Type"] = "application/json";
          init.body = JSON.stringify(opts.body);
        }

        let response;
        try {
          response = await fetch(API_BASE + endpoint, init);
        } catch (_) {
          throw new Error("Network error. Could not reach portal API.");
        }

        let payload = {};
        try {
          payload = await response.json();
        } catch (_) {
          payload = {};
        }

        if (response.status === 401) {
          throw new Error("__UNAUTHORIZED__");
        }

        if (!response.ok || payload.ok === false) {
          throw new Error(payload.error || "Request failed (" + response.status + ")");
        }

        return payload;
      }

      function handleUnauthorized(message) {
        showLogin();
        showLoginError(message || "Session expired. Sign in again.");
      }

      function jobsOn(dateStr) {
        return state.jobs
          .filter((j) => !j.deleted && j.date === dateStr)
          .sort((a, b) => String(a.time).localeCompare(String(b.time)));
      }

      function classifyArea(address) {
        const value = String(address || "").toLowerCase();
        for (const group of AREA_KEYWORDS) {
          for (const term of group.terms) {
            if (value.includes(term)) return group.area;
          }
        }
        return "Other";
      }

      function syncHeatmapDays() {
        const monthValue = el.heatmapMonth.value || state.heatmapMonth;
        const max = daysInMonth(monthValue);
        const existing = el.heatmapDay.value || state.heatmapDay || "";
        const current = Number(existing);

        el.heatmapDay.innerHTML = "";

        const allOption = document.createElement("option");
        allOption.value = "";
        allOption.textContent = "All days";
        el.heatmapDay.appendChild(allOption);

        for (let day = 1; day <= max; day += 1) {
          const opt = document.createElement("option");
          opt.value = String(day).padStart(2, "0");
          opt.textContent = String(day);
          el.heatmapDay.appendChild(opt);
        }

        if (current >= 1 && current <= max) {
          el.heatmapDay.value = String(current).padStart(2, "0");
        } else {
          el.heatmapDay.value = "";
        }
      }

      function renderHeatmap() {
        if (!el.heatmapMonth || !el.heatmapDay || !el.heatmapGrid) return;

        if (!el.heatmapMonth.value) {
          el.heatmapMonth.value = state.heatmapMonth;
        }

        state.heatmapMonth = el.heatmapMonth.value || state.heatmapMonth;
        syncHeatmapDays();

        if (state.heatmapDay && !el.heatmapDay.value) {
          el.heatmapDay.value = state.heatmapDay;
        }
        state.heatmapDay = el.heatmapDay.value || "";

        const monthValue = state.heatmapMonth;
        const dayValue = state.heatmapDay;
        const monthLabel = formatMonthLabel(monthValue);
        const dateFilter = monthValue + "-" + dayValue;

        const filtered = state.jobs.filter(function (job) {
          if (job.deleted) return false;
          if (!job.date.startsWith(monthValue + "-")) return false;
          if (dayValue && job.date !== dateFilter) return false;
          return true;
        });

        const counts = {};
        for (const area of AREA_ORDER) counts[area] = 0;
        for (const job of filtered) {
          const area = classifyArea(job.address);
          counts[area] = (counts[area] || 0) + 1;
        }

        const entries = Object.entries(counts).sort(function (a, b) {
          if (b[1] === a[1]) return a[0].localeCompare(b[0]);
          return b[1] - a[1];
        });

        const total = filtered.length;
        const top = entries[0];
        const topArea = top && top[1] > 0 ? top[0] : "Wellington";

        if (total === 0) {
          el.heatmapSummary.textContent = "No jobs scheduled for " + (dayValue ? dayValue + " " + monthLabel : monthLabel) + ".";
          el.heatmapLine.textContent = "I am in Wellington today.";
        } else if (dayValue) {
          el.heatmapSummary.textContent = total + " job" + (total === 1 ? "" : "s") + " on " + dayValue + " " + monthLabel + ". Busiest area: " + topArea + ".";
          el.heatmapLine.textContent = "I am in " + topArea + " today.";
        } else {
          el.heatmapSummary.textContent = total + " job" + (total === 1 ? "" : "s") + " in " + monthLabel + ". Busiest area: " + topArea + ".";
          el.heatmapLine.textContent = "Most of our bookings this month are in " + topArea + ".";
        }

        const maxCount = Math.max.apply(null, entries.map(function (item) { return item[1]; }).concat([0]));
        el.heatmapGrid.innerHTML = "";

        for (const entry of entries) {
          const area = entry[0];
          const count = entry[1];
          const ratio = maxCount > 0 ? count / maxCount : 0;
          let tone = "bg-white/5 ring-white/10 text-slate-300";
          if (ratio >= 0.8) tone = "bg-amber-500/25 ring-amber-300/60 text-amber-100";
          else if (ratio >= 0.5) tone = "bg-amber-500/18 ring-amber-300/45 text-amber-200";
          else if (ratio > 0) tone = "bg-amber-500/12 ring-amber-300/30 text-slate-100";

          const card = document.createElement("div");
          card.className = "rounded-xl p-3 ring-1 " + tone;
          card.innerHTML =
            '<p class="text-sm font-semibold">' + safeText(area) + "</p>" +
            '<p class="mt-1 text-xs">' + count + " job" + (count === 1 ? "" : "s") + "</p>";
          el.heatmapGrid.appendChild(card);
        }
      }

      function renderCalendar() {
        const year = state.month.getFullYear();
        const month = state.month.getMonth();
        const firstDay = new Date(year, month, 1);
        const start = new Date(firstDay);
        start.setDate(firstDay.getDate() - firstDay.getDay());

        el.monthLabel.textContent = state.month.toLocaleDateString("en-NZ", { month: "long", year: "numeric" });
        el.calendarGrid.innerHTML = "";

        const counts = {};
        for (const j of state.jobs) {
          if (j.deleted) continue;
          counts[j.date] = (counts[j.date] || 0) + 1;
        }

        for (let i = 0; i < 42; i += 1) {
          const d = new Date(start);
          d.setDate(start.getDate() + i);
          const key = dateKey(d);
          const isCurrentMonth = d.getMonth() === month;
          const isSelected = key === state.selectedDate;
          const isToday = key === dateKey(new Date());
          const count = counts[key] || 0;

          const btn = document.createElement("button");
          btn.type = "button";
          btn.dataset.date = key;
          btn.className =
            "relative min-h-[74px] rounded-lg border px-2 py-1 text-left transition " +
            (isCurrentMonth ? "border-white/10 bg-[var(--brand-bg)]" : "border-white/5 bg-[var(--brand-bg)]/50 text-slate-500") +
            (isSelected ? " ring-2 ring-amber-400" : " hover:border-amber-400/40");

          const day = document.createElement("div");
          day.className = "text-sm font-semibold " + (isToday ? "text-amber-300" : "");
          day.textContent = String(d.getDate());
          btn.appendChild(day);

          if (count > 0) {
            const badge = document.createElement("div");
            badge.className = "mt-2 inline-flex rounded-full bg-amber-500/20 px-2 py-0.5 text-xs text-amber-300";
            badge.textContent = count + " job" + (count > 1 ? "s" : "");
            btn.appendChild(badge);
          }

          el.calendarGrid.appendChild(btn);
        }
      }

      function renderDay() {
        const jobs = jobsOn(state.selectedDate);
        el.dayTitle.textContent = "Jobs for " + formatLongDate(state.selectedDate);
        el.dayCount.textContent = jobs.length + " job" + (jobs.length === 1 ? "" : "s");

        el.jobList.innerHTML = "";
        if (!jobs.length) {
          el.jobEmpty.classList.remove("hidden");
          return;
        }
        el.jobEmpty.classList.add("hidden");

        for (const j of jobs) {
          const card = document.createElement("article");
          card.className = "rounded-xl bg-[var(--brand-bg)] p-4 ring-1 ring-white/10";
          card.innerHTML =
            '<div class="flex items-start justify-between gap-2">' +
              '<div>' +
                '<h3 class="font-semibold">' + safeText(j.customer) + '</h3>' +
                '<p class="text-xs text-slate-400">' + safeText(j.time) + " • " + safeText(j.status || "Booked") + "</p>" +
              "</div>" +
              '<div class="flex gap-2">' +
                '<button type="button" data-action="edit" data-id="' + safeText(j.id) + '" class="btn btn-outline px-3 py-1 text-xs">Edit</button>' +
                '<button type="button" data-action="delete" data-id="' + safeText(j.id) + '" class="btn btn-outline px-3 py-1 text-xs">Delete</button>' +
              "</div>" +
            "</div>" +
            '<p class="mt-2 text-sm text-slate-200">' + safeText(j.summary) + "</p>" +
            '<div class="mt-3 flex flex-wrap gap-2">' +
              '<a class="btn btn-primary px-3 py-1 text-xs" href="tel:' + safeText(j.phone) + '">Call</a>' +
              '<a class="btn btn-secondary px-3 py-1 text-xs" target="_blank" rel="noreferrer" href="https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(j.address) + '">Maps</a>' +
            "</div>" +
            '<p class="mt-2 text-xs text-slate-400">' + safeText(j.address) + "</p>";
          el.jobList.appendChild(card);
        }
      }

      function clearForm() {
        state.editId = null;
        el.formTitle.textContent = "Add Job";
        el.jobForm.reset();
        el.inputDate.value = state.selectedDate;
        el.inputStatus.value = "Booked";
      }

      function fillForm(job) {
        state.editId = job.id;
        el.formTitle.textContent = "Edit Job";
        el.inputDate.value = job.date;
        el.inputTime.value = job.time;
        el.inputCustomer.value = job.customer;
        el.inputPhone.value = job.phone;
        el.inputAddress.value = job.address;
        el.inputSummary.value = job.summary;
        el.inputStatus.value = job.status || "Booked";
      }

      function normalizeJob(job) {
        return {
          id: String(job && job.id ? job.id : ""),
          date: String(job && job.date ? job.date : ""),
          time: String(job && job.time ? job.time : ""),
          customer: String(job && job.customer ? job.customer : ""),
          phone: String(job && job.phone ? job.phone : ""),
          address: String(job && job.address ? job.address : ""),
          summary: String(job && job.summary ? job.summary : ""),
          status: String(job && job.status ? job.status : "Booked"),
          deleted: Boolean(job && job.deleted)
        };
      }

      async function loadJobs(silent) {
        try {
          const data = await apiRequest("jobs.php");
          state.jobs = Array.isArray(data.jobs) ? data.jobs.map(normalizeJob) : [];
          renderCalendar();
          renderDay();
          renderHeatmap();
          if (!silent) setPortalStatus("Jobs refreshed.");
        } catch (err) {
          if (err.message === "__UNAUTHORIZED__") {
            handleUnauthorized("Session expired. Sign in again.");
            return;
          }
          setPortalStatus("Could not load jobs: " + err.message, true);
        }
      }

      async function saveFormJob() {
        if (state.saveInFlight) return;

        const job = {
          id: state.editId || String(Date.now()),
          date: el.inputDate.value,
          time: el.inputTime.value,
          customer: el.inputCustomer.value.trim(),
          phone: el.inputPhone.value.trim(),
          address: el.inputAddress.value.trim(),
          summary: el.inputSummary.value.trim(),
          status: el.inputStatus.value,
          deleted: false
        };

        if (!job.date || !job.time || !job.customer || !job.phone || !job.address || !job.summary) return;

        state.saveInFlight = true;
        setPortalStatus("Saving job...");
        try {
          await apiRequest("jobs.php", { method: "POST", body: { job: job } });
          state.selectedDate = job.date;
          const pickedDate = parseDate(job.date);
          state.month = new Date(pickedDate.getFullYear(), pickedDate.getMonth(), 1);
          clearForm();
          await loadJobs(true);
          setPortalStatus("Job saved.");
        } catch (err) {
          if (err.message === "__UNAUTHORIZED__") {
            handleUnauthorized("Session expired. Sign in again.");
            return;
          }
          setPortalStatus("Could not save job: " + err.message, true);
        } finally {
          state.saveInFlight = false;
        }
      }

      async function deleteJob(id) {
        setPortalStatus("Deleting job...");
        try {
          await apiRequest("jobs.php", { method: "POST", body: { deleteId: id } });
          await loadJobs(true);
          clearForm();
          setPortalStatus("Job deleted.");
        } catch (err) {
          if (err.message === "__UNAUTHORIZED__") {
            handleUnauthorized("Session expired. Sign in again.");
            return;
          }
          setPortalStatus("Could not delete job: " + err.message, true);
        }
      }

      function startPolling() {
        stopPolling();
        state.pollTimer = setInterval(function () {
          loadJobs(true);
        }, 45000);
      }

      function stopPolling() {
        if (state.pollTimer) {
          clearInterval(state.pollTimer);
          state.pollTimer = null;
        }
      }

      function bindEvents() {
        el.loginForm.addEventListener("submit", async function (e) {
          e.preventDefault();
          clearLoginError();
          setPortalStatus("Signing in...");
          try {
            await apiRequest("login.php", {
              method: "POST",
              body: {
                username: (el.loginUser.value || "").trim(),
                password: (el.loginPass.value || "").trim()
              }
            });

            showApp();
            clearForm();
            await loadJobs(true);
            startPolling();
            setPortalStatus("Signed in.");
          } catch (err) {
            showLogin();
            showLoginError(err.message === "__UNAUTHORIZED__" ? "Invalid username or password." : err.message);
          }
        });

        el.logoutBtn.addEventListener("click", async function () {
          try {
            await apiRequest("logout.php", { method: "POST" });
          } catch (_) {}
          showLogin();
          clearLoginError();
          setPortalStatus("Signed out.");
        });

        el.refreshBtn.addEventListener("click", function () {
          loadJobs(false);
        });

        el.todayBtn.addEventListener("click", function () {
          const d = new Date();
          state.selectedDate = dateKey(d);
          state.month = new Date(d.getFullYear(), d.getMonth(), 1);
          state.heatmapMonth = state.selectedDate.slice(0, 7);
          state.heatmapDay = state.selectedDate.slice(8, 10);
          el.heatmapMonth.value = state.heatmapMonth;
          syncHeatmapDays();
          el.heatmapDay.value = state.heatmapDay;
          renderCalendar();
          renderDay();
          renderHeatmap();
          clearForm();
        });

        el.monthPrev.addEventListener("click", function () {
          state.month = new Date(state.month.getFullYear(), state.month.getMonth() - 1, 1);
          renderCalendar();
        });

        el.monthNext.addEventListener("click", function () {
          state.month = new Date(state.month.getFullYear(), state.month.getMonth() + 1, 1);
          renderCalendar();
        });

        el.calendarGrid.addEventListener("click", function (e) {
          const btn = e.target && e.target.closest && e.target.closest("button[data-date]");
          if (!btn) return;
          state.selectedDate = btn.dataset.date;
          renderCalendar();
          renderDay();
          clearForm();
        });

        el.jobForm.addEventListener("submit", function (e) {
          e.preventDefault();
          saveFormJob();
        });

        el.jobClear.addEventListener("click", function () {
          clearForm();
        });

        el.jobList.addEventListener("click", function (e) {
          const btn = e.target && e.target.closest && e.target.closest("button[data-action][data-id]");
          if (!btn) return;
          const id = btn.dataset.id;
          const action = btn.dataset.action;
          const job = state.jobs.find((x) => x.id === id);
          if (!job || job.deleted) return;
          if (action === "edit") {
            fillForm(job);
            return;
          }
          if (action === "delete") {
            if (!window.confirm("Delete this job?")) return;
            deleteJob(id);
          }
        });

        el.heatmapMonth.addEventListener("change", function () {
          state.heatmapMonth = el.heatmapMonth.value || state.heatmapMonth;
          state.heatmapDay = "";
          el.heatmapDay.value = "";
          renderHeatmap();
        });

        el.heatmapDay.addEventListener("change", function () {
          state.heatmapDay = el.heatmapDay.value || "";
          renderHeatmap();
        });

        el.heatmapCopyLine.addEventListener("click", async function () {
          const text = el.heatmapLine.textContent || "";
          try {
            if (navigator.clipboard && navigator.clipboard.writeText) {
              await navigator.clipboard.writeText(text);
              setPortalStatus("Heatmap line copied.");
              return;
            }
          } catch (_) {}
          setPortalStatus("Copy failed. Select and copy manually.", true);
        });
      }

      async function boot() {
        bindEvents();
        setPortalStatus("Checking session...");
        try {
          const me = await apiRequest("me.php");
          if (!me.authenticated) {
            showLogin();
            setPortalStatus("Sign in to access jobs.");
            return;
          }

          showApp();
          el.heatmapMonth.value = state.heatmapMonth;
          syncHeatmapDays();
          el.heatmapDay.value = state.heatmapDay;
          clearForm();
          await loadJobs(true);
          startPolling();
          setPortalStatus("Connected.");
        } catch (err) {
          showLogin();
          showLoginError("Portal API unavailable. Check database setup.");
          setPortalStatus("Portal API error: " + err.message, true);
        }
      }

      boot();
    })();
  </script>
</Layout>
