---
import Layout from "../layouts/WMBase.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Picture from "../components/Picture.astro";
import FAQ from "../components/FAQ.astro";
import QuoteInline from "../components/QuoteInline.astro";

const title = "Aluminium Window & Sliding Door Repairs in Wellington Region";
const description = "Wellington and Hutt Valley aluminium window and sliding door repairs, lock picking and lockout entry, handles and locks, mitre and sill reseals, and hardware replacements.";
const canonical = "https://windowmaintenance.co.nz/";

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Window Maintenance",
  url: canonical,
  telephone: "+6421638205",
  email: "mailto:baeley@windowmaintenance.co.nz",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Wellington",
    addressRegion: "WGN",
    addressCountry: "NZ",
  },
  areaServed: ["Central Wellington", "Porirua", "Lower Hutt", "Upper Hutt", "Petone", "Kapiti"],
};

const website = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  url: canonical,
  name: "Window Maintenance",
};

const services = [
  { href: "/services/sliding-door-repairs/", title: "Sliding / Ranchslider Door Repairs", copy: "Rollers replaced, tracks refurbished and panels re-aligned so aluminium sliders glide properly again." },
  { href: "/services/window-repairs/", title: "Aluminium Window Repairs", copy: "Awning stays, hinges, sash handles, Yale window locks and latches serviced or replaced." },
  { href: "/services/joinery-repairs/", title: "Aluminium Joinery Repairs", copy: "A broader page for single- and double-glazed aluminium joinery repairs across windows and doors." },
  { href: "/services/mitre-reseal/", title: "Mitre & Sill Reseal", copy: "Proper in-frame reseals for leaking aluminium sliders and windows where water is tracking at corners and sills." },
  { href: "/services/hardware-wedge-replacement/", title: "Handles, Locks & Hardware", copy: "Window handles, door handles, Yale hardware, wedges, keepers and other hard-to-match aluminium joinery parts." },
  { href: "/services/lock-picking/", title: "Lock Picking & Lockout Entry", copy: "Non-destructive entry for compatible locks, plus cylinder replacement when a lock has failed." },
];

const popularSearches = [
  { href: "/services/window-repairs/", title: "Aluminium window repairs Wellington", copy: "For bent awning stays, tired hinges, stiff latches, broken sash handles and Yale window locks." },
  { href: "/services/sliding-door-repairs/", title: "Sliding door repair and ranchslider repairs", copy: "For flat rollers, dented tracks, dropped panels and sliders that have to be dragged shut." },
  { href: "/services/joinery-repairs/", title: "Aluminium joinery repairs", copy: "For broader single- and double-glazed joinery issues across aluminium windows and doors." },
  { href: "/services/mitre-reseal/", title: "Reseal aluminium windows and leaking sliders", copy: "For mitre leaks, sill leaks and water tracking into aluminium joinery during Wellington weather." },
  { href: "/services/hardware-wedge-replacement/", title: "Window handles, door handles and window locks", copy: "For Doric and Yale hardware, wedges, keepers and other replacement parts on aluminium joinery." },
  { href: "/services/lock-picking/", title: "Lock picking Wellington", copy: "For compatible residential lockouts where you need access without unnecessary damage." },
];

const areaLinks = [
  { href: "/areas/central-wellington/", title: "Central Wellington", copy: "Rental repairs, sticking sliders and older aluminium joinery in city apartments and hillside homes." },
  { href: "/areas/lower-hutt/", title: "Lower Hutt", copy: "Ranchslider rollers, window handles and leak repairs across Lower Hutt suburbs and coastal streets." },
  { href: "/areas/upper-hutt/", title: "Upper Hutt", copy: "Window stays, locks and draught fixes for family homes and investment properties in Upper Hutt." },
  { href: "/areas/porirua/", title: "Porirua", copy: "Corroded hardware, ranchslider repairs and sill leaks fixed across Porirua and nearby coastal areas." },
  { href: "/areas/petone/", title: "Petone", copy: "Salt-air hardware issues, seized locks and rattling aluminium windows repaired without the sales pitch." },
  { href: "/areas/kapiti/", title: "Kapiti", copy: "Kapiti aluminium door, ranchslider and window repairs, plus lockouts and reseals where wind-driven rain gets in." },
];

const faqs = [
  { q: "Do you repair single and double glazed aluminium joinery?", a: "Yes. We work on both single- and double-glazed aluminium windows and doors, including rollers, seals, hardware and alignment." },
  { q: "Do you work across the whole Wellington region?", a: "Yes. We cover Central Wellington, the Hutt Valley, Porirua, Petone and Kapiti every week." },
  { q: "How fast can you quote?", a: "Send photos or describe the issue and we usually reply the same day. Emergency call-outs are available for stuck sliders." },
  { q: "Can you source older aluminium parts?", a: "We stock common profiles and work with national suppliers to match out-of-production rollers, wedges, handles and locks." },
  { q: "What happens if glass breaks while you are working on it?", a: "Most glass we work on is older and can have hidden edge damage or movement in the frame. We take care, but sometimes a pane can crack during normal repair or adjustment. If glass breaks during normal work on existing or aged glass, replacement glass and reglazing are charged at standard rates. If we clearly damage a sound pane through a mistake on our part, we will discuss a fair way forward. Nothing here affects your rights under New Zealand consumer law." },
  { q: "Can you fix leaks at the sill or mitred corners?", a: "Yes. We open the joinery, back-seal the mitres, re-seal the sill and keep drainage paths clear. See our mitre and sill reseal service for details." },
  { q: "Do you offer lock picking?", a: "Yes. We provide non-destructive entry for compatible locks and can replace cylinders if required. We only open doors with verified occupancy or authority." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<Layout title={title} description={description} canonical={canonical} schema={[localBusiness, website, faqSchema]}>
  <section class="bg-gradient-to-b from-[#0a2540] via-[#0b1220] to-[#0a2540]">
    <div class="mx-auto max-w-6xl px-6 py-16 lg:py-24">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-amber-400">Wellington single &amp; double-glazed aluminium joinery specialists</p>
          <h1 class="mt-4 text-4xl font-bold leading-tight text-white md:text-5xl">Sliding door and aluminium window repairs done right.</h1>
          <p class="mt-4 text-lg text-slate-300">Single- and double-glazed aluminium joinery repairs for Wellington homes and rentals. We fix ranchsliders, awning windows, window handles, door handles, window locks, Yale hardware, drafts, leaks and sticking sashes across Wellington, Lower Hutt, Upper Hutt, Porirua and Kapiti.</p>
          <div class="mt-6 flex flex-wrap items-center gap-4">
            <a href="tel:+6421638205" id="cta-call-home" data-cta="call" class="btn btn-primary">Call 021 638 205</a>
            <a href="/contact/" class="btn btn-secondary">Get a fast quote</a>
          </div>
          <ul class="mt-6 grid gap-2 text-slate-300 md:grid-cols-2">
            <li class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-amber-400"></span>Sliding door roller and track repairs</li>
            <li class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-amber-400"></span>Awning stays, hinges and restrictors</li>
            <li class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-amber-400"></span>Window handles, door handles and window locks</li>
            <li class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-amber-400"></span>Draught and leak diagnosis</li>
            <li class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-amber-400"></span>Mitre and sill reseals</li>
            <li class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-amber-400"></span>Lock picking and cylinder replacement</li>
          </ul>
        </div>
        <div>
          <QuoteInline
            title="Get a fast quote"
            subtitle="Name and phone is enough. Tell us what is sticking, leaking or broken and we will usually reply the same day during business hours."
            buttonLabel="Get my fast quote"
            source="home_hero_form"
            className="mt-0 shadow-2xl"
          />
          <div class="mt-4 grid gap-3 md:grid-cols-2">
            <div class="rounded-2xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
              <p class="text-sm font-semibold uppercase tracking-[0.25em] text-amber-400">Best for</p>
              <p class="mt-2 text-sm text-slate-300">Urgent ranchslider repairs, leaking sills, broken window stays, handles, locks and same-week quoting.</p>
            </div>
            <div class="rounded-2xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
              <p class="text-sm font-semibold uppercase tracking-[0.25em] text-amber-400">What to send</p>
              <p class="mt-2 text-sm text-slate-300">Suburb, short issue description and photos if you have them. We can still quote from a quick message first.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-12 flex flex-wrap items-center gap-6 text-sm text-slate-400">
        <span>Trusted locally by property managers, builders and homeowners</span>
        <span class="h-px flex-1 bg-slate-700"></span>
        <span>Same-day replies • Tidy workmanship • Fully insured</span>
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 bg-[var(--brand-bg)]">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-amber-400">What people actually search</p>
      <h2 class="mt-2 text-3xl font-bold text-white">High-intent repair pages built to rank and convert</h2>
      <p class="mt-3 max-w-3xl text-slate-300">Most visitors are not searching for a generic handyman. They are looking for aluminium window repairs, ranchslider repairs, leaking aluminium windows, window handles, Yale window locks and aluminium joinery repairs. These are the pages we want Google to understand and rank.</p>
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        {popularSearches.map((item) => (
          <a href={item.href} class="card-link rounded-2xl bg-[var(--brand-surface)] p-6 ring-1 ring-white/10">
            <h3 class="text-lg font-bold text-white">{item.title}</h3>
            <p class="mt-3 text-sm text-slate-300">{item.copy}</p>
            <span class="mt-4 inline-flex items-center text-sm font-semibold text-amber-300">Open page &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 bg-[var(--brand-bg)]">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="md:flex md:items-center md:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-amber-400">What we fix daily</p>
          <h2 class="mt-2 text-3xl font-bold text-white">Parts and hardware carried on the van</h2>
        </div>
        <a href="/gallery/" class="mt-4 inline-flex items-center text-sm font-semibold text-amber-300 md:mt-0">See more work &rarr;</a>
      </div>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 md:grid-cols-3">
        <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
          <div class="ratio-4-3 card-frame">
            <Picture base="sliding-door-roller" alt="Sliding door roller carriage with brass wheel" className="h-full w-full object-cover" />
          </div>
          <figcaption>Sliding door rollers</figcaption>
        </figure>
        <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
          <div class="ratio-4-3 card-frame">
            <Picture base="ranchslider-handle-lockset" alt="Ranchslider handle and lock set" className="h-full w-full object-cover" />
          </div>
          <figcaption>Ranchslider handles and locks</figcaption>
        </figure>
        <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
          <div class="ratio-4-3 card-frame">
            <Picture base="security-stays" alt="Sash window security stays and restrictors" className="h-full w-full object-cover" />
          </div>
          <figcaption>Security stays</figcaption>
        </figure>
        <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
          <div class="ratio-4-3 card-frame">
            <Picture base="sash-handles" alt="Aluminium sash window handle pair" className="h-full w-full object-cover" />
          </div>
          <figcaption>Sash handles</figcaption>
        </figure>
        <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
          <div class="ratio-4-3 card-frame">
            <Picture base="hinge" alt="Aluminium window hinge replacement" className="h-full w-full object-cover" />
          </div>
          <figcaption>Window hinges</figcaption>
        </figure>
        <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
          <div class="ratio-4-3 card-frame">
            <Picture base="glazing-wedge" alt="Glazing wedge and rubber seal profile" className="h-full w-full object-cover" />
          </div>
          <figcaption>Rubber wedges and seals</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 bg-[var(--brand-bg)]">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-amber-400">Guides</p>
      <h2 class="mt-2 text-3xl font-bold">Helpful repair guides for Wellington homes</h2>
      <p class="mt-3 text-slate-300">Practical tips on rollers, seals and joinery issues we see every week in Wellington, Porirua and the Hutt Valley.</p>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <a class="card-link rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10 font-medium text-slate-200 hover:text-amber-300" href="/blog/sliding-door-repair-costs-wellington/">Sliding door repair costs in Wellington</a>
        <a class="card-link rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10 font-medium text-slate-200 hover:text-amber-300" href="/blog/resealing-imported-sliders-wellington/">Why aluminium sliders leak and how we reseal them</a>
        <a class="card-link rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10 font-medium text-slate-200 hover:text-amber-300" href="/blog/window-stays-replacement-guide/">Do your window stays need replacing?</a>
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 bg-[var(--brand-bg)]">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="md:flex md:items-center md:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-amber-400">Services</p>
          <h2 class="mt-2 text-3xl font-bold">One team for every aluminium window and door issue</h2>
        </div>
        <a href="/services/" class="mt-4 inline-flex items-center text-sm font-semibold text-amber-300 md:mt-0">View full services &rarr;</a>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        {services.map((service) => (
          <a href={service.href} class="card-link rounded-2xl bg-[var(--brand-surface)] p-6 ring-1 ring-white/10">
            <div class="text-sm font-semibold uppercase tracking-[0.3em] text-amber-400">{service.title}</div>
            <p class="mt-3 text-sm text-slate-300">{service.copy}</p>
            <span class="mt-4 inline-flex items-center text-sm font-semibold text-amber-300">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-white/5">
    <div class="mx-auto max-w-6xl px-6 py-16 md:flex md:items-center md:gap-10">
      <div class="md:w-1/2">
        <picture>
          <source
            type="image/webp"
            srcset="/img/window-stay-replacement-480.webp 480w, /img/window-stay-replacement-640.webp 640w, /img/window-stay-replacement-768.webp 768w"
            sizes="(min-width: 768px) 50vw, 100vw"
          />
          <img
            src="/img/window-stay-replacement-640.webp"
            alt="Window stay replacement case study"
            class="w-full rounded-2xl object-cover"
            width="640"
            height="853"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>
      <div class="mt-8 md:mt-0 md:w-1/2">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-amber-400">Latest job</p>
        <h2 class="mt-2 text-3xl font-bold">Storm-bent awning stays replaced the same week</h2>
        <p class="mt-4 text-slate-300">We removed bent stays, fitted new hardware, re-aligned the sash and tested seals, leaving the window smooth, quiet and leak-free.</p>
        <ul class="mt-4 list-disc space-y-1 pl-5 text-slate-300">
          <li>Awning stays and restrictors replaced</li>
          <li>Hinges, handles and locks serviced</li>
          <li>Draught and leak diagnosis carried out</li>
        </ul>
        <a href="/blog/awning-stay-repair-storm/" class="mt-5 inline-flex items-center text-sm font-semibold text-amber-300">Read the job recap &rarr;</a>
      </div>
    </div>
  </section>

  <section class="border-t border-white/5">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="md:flex md:items-center md:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-amber-400">Service areas</p>
          <h2 class="mt-2 text-3xl font-bold">Every suburb, one team</h2>
          <p class="mt-3 text-slate-300">Central Wellington • Lower Hutt • Upper Hutt • Porirua • Petone • Kapiti</p>
        </div>
        <a href="/areas/" class="mt-4 inline-flex items-center text-sm font-semibold text-amber-300 md:mt-0">See full coverage &rarr;</a>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {areaLinks.map((area) => (
          <a href={area.href} class="card-link rounded-2xl bg-[var(--brand-surface)] p-6 ring-1 ring-white/10">
            <h3 class="text-lg font-bold text-white">{area.title}</h3>
            <p class="mt-3 text-sm text-slate-300">{area.copy}</p>
            <span class="mt-4 inline-flex items-center text-sm font-semibold text-amber-300">View {area.title} page &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 bg-[var(--brand-bg)]">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-amber-400">FAQ</p>
      <FAQ heading="Questions we’re asked most" items={faqs} />
    </div>
  </section>

  <ContactCTA />
</Layout>
