---
import Layout from "../layouts/WMBase.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
const title = "Contact & Quotes | Wellington window & door repairs";
const description = "Request a fast quote for single and double-glazed aluminium window and sliding door repairs across Wellington, Porirua, Lower Hutt, Upper Hutt and Kāpiti.";
const canonical = "https://windowmaintenance.co.nz/contact/";
---
<Layout title={title} description={description} canonical={canonical}>
  <Breadcrumbs />
  <section class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <h1 class="text-3xl font-extrabold">Contact & Quotes</h1>
        <p class="mt-2 text-slate-300">Same-day replies during business hours. Free quotes for aluminium window repairs, sliding door repairs, leaks, locks and hardware across Wellington, Porirua, Lower Hutt, Upper Hutt, Petone and Kāpiti.</p>
        <p class="mt-3 text-sm text-slate-300">Open now for same-week bookings where possible. If you are stuck outside, call rather than filling in the form.</p>
        <form action="https://formspree.io/f/xpwqlqjb" method="POST" class="mt-6 space-y-4 rounded-2xl bg-[var(--brand-surface)] p-6 ring-1 ring-white/10" onsubmit="if(window && window.dataLayer){window.dataLayer.push({event:'lead_submit', source:'contact_form', path: location.pathname});}">
          <input type="hidden" name="_subject" value="Website enquiry &mdash; Window Maintenance" />
          <input type="hidden" name="_redirect" value="/thanks/" />
          <input type="hidden" name="source_form" value="contact_form" />
          <input type="text" name="_honeypot" style="display:none" tabindex="-1" autocomplete="off" />
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="text-sm">Name</span>
              <input name="name" required autocomplete="name" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" />
            </label>
            <label class="block">
              <span class="text-sm">Phone</span>
              <input name="phone" type="tel" required autocomplete="tel" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" />
            </label>
            <label class="block">
              <span class="text-sm">Email</span>
              <input type="email" name="email" autocomplete="email" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" />
            </label>
            <label class="block">
              <span class="text-sm">Suburb</span>
              <input name="suburb" autocomplete="address-level2" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" />
            </label>
          </div>
          <label class="block">
            <span class="text-sm">What needs fixing?</span>
            <textarea name="message" rows="5" class="mt-1 w-full rounded-lg bg-[var(--brand-bg)] px-3 py-2 ring-1 ring-white/10" placeholder="Example: ranchslider hard to slide, awning stay bent, Yale window lock not latching, leak at sill corner"></textarea>
          </label>
          <div class="flex flex-wrap gap-3">
            <button class="btn btn-primary" type="submit" onclick="if(window && window.gtag_report_conversion){gtag_report_conversion();}">Get my fast quote</button>
            <a class="btn btn-outline" href="mailto:baeley@windowmaintenance.co.nz" onclick="if(window && window.gtag_report_conversion){gtag_report_conversion();}">Email instead</a>
          </div>
        </form>
        <p class="mt-3 text-xs text-slate-400">After you submit, you’ll land on our <a class="text-amber-400" href="/thanks/">thank-you page</a> so you know it sent.</p>
      </div>

      <aside class="space-y-4">
        <div class="rounded-2xl bg-[var(--brand-surface)] p-6 ring-1 ring-white/10">
          <h2 class="text-xl font-bold">Fastest way to get booked</h2>
          <ul class="mt-4 space-y-3 text-sm text-slate-300">
            <li class="flex gap-3"><span class="mt-1 h-2 w-2 rounded-full bg-amber-400"></span><span>Tell us the suburb and whether it is a window, slider, leak or lock issue.</span></li>
            <li class="flex gap-3"><span class="mt-1 h-2 w-2 rounded-full bg-amber-400"></span><span>Add photos if you have them. If not, send the form anyway and we can ask for them after.</span></li>
            <li class="flex gap-3"><span class="mt-1 h-2 w-2 rounded-full bg-amber-400"></span><span>We reply with likely fix, rough price range and next available slot where possible.</span></li>
          </ul>
        </div>
        <div class="rounded-2xl bg-[var(--brand-surface)] p-6 ring-1 ring-white/10">
          <h2 class="text-xl font-bold">Prefer to call?</h2>
          <p class="mt-3 text-sm text-slate-300">Best for stuck doors, lockouts, urgent leaks or jobs that need same-day triage.</p>
          <div class="mt-4 flex flex-wrap gap-3">
            <a href="tel:+6421638205" id="cta-call-contact" data-cta="call" class="btn btn-primary">Call 021 638 205</a>
            <a href="/services/" class="btn btn-outline">See services</a>
          </div>
        </div>
        <div class="rounded-2xl bg-[var(--brand-surface)] p-6 ring-1 ring-white/10">
          <h2 class="text-xl font-bold">Common jobs we quote from this page</h2>
          <p class="mt-3 text-sm text-slate-300">Sliding/ranchslider rollers, single- and double-glazed aluminium window repairs, Yale handles and locks, awning stays, draft sealing, mitre reseals and lock picking for compatible systems.</p>
        </div>
      </aside>
    </div>
  </section>
</Layout>
