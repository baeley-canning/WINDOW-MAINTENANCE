---
import Layout from "../layouts/WMBase.astro";

const title = "Thanks | Wellington window & door repair enquiry received";
const description = "Thanks for your message about single or double-glazed aluminium joinery repairs. We will get back to you shortly with next steps or a quote.";
const canonical = "https://windowmaintenance.co.nz/thanks/";
---
<Layout title={title} description={description} canonical={canonical} noindex={true}>
  <section class="mx-auto max-w-3xl px-6 py-20 text-center">
    <div class="rounded-3xl border border-emerald-400/30 bg-emerald-500/10 px-6 py-10 text-left shadow-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-emerald-200">Quote form sent successfully</p>
      <h1 class="mt-3 text-4xl font-extrabold">We have received your message.</h1>
      <p class="mt-4 text-lg text-emerald-50">You do not need to submit the form again, send a separate email, or call as well unless the job is urgent.</p>
      <div class="mt-6 grid gap-3 rounded-2xl bg-black/10 p-5 text-sm text-emerald-50 md:grid-cols-3">
        <p><strong>What happens next:</strong><br />We review your details and reply with the next step or a quote.</p>
        <p><strong>If you forgot something:</strong><br />Wait for our reply and send the extra detail then.</p>
        <p><strong>If it is urgent:</strong><br />Call <a class="text-amber-300" id="cta-call-thanks" data-cta="call" href="tel:+6421638205">021 638 205</a>.</p>
      </div>
      <a class="mt-6 inline-block btn btn-primary" href="/">Back to home</a>
    </div>
    <script is:inline>
      if (window && window.dataLayer) {
        window.dataLayer.push({ event: "lead_submit", source: "thanks_page" });
      }
      try {
        window.localStorage.setItem("wmLeadRecentSubmission", JSON.stringify({
          ts: Date.now(),
          path: window.location.pathname
        }));
      } catch (_) {}
    </script>
  </section>
</Layout>
