---
import Layout from "../../layouts/WMBase.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import QuoteInline from "../../components/QuoteInline.astro";
import FAQ from "../../components/FAQ.astro";

const title = "Aluminium Joinery Repairs Wellington | Windows, Doors, Handles & Locks";
const description = "Aluminium joinery repairs across Wellington for single and double glazed windows and doors: handles, locks, stays, rollers, wedges, hinges and leak-related repairs.";
const canonical = "https://windowmaintenance.co.nz/services/joinery-repairs/";

const faqItems = [
  {
    q: "What is included in aluminium joinery repairs?",
    a: "We repair aluminium windows and doors including handles, locks, stays, hinges, rollers, wedges, seals, alignment issues and leak-related faults."
  },
  {
    q: "Do you work on single and double glazed aluminium joinery?",
    a: "Yes. We service both single and double glazed aluminium joinery across Wellington, Porirua, Lower Hutt, Upper Hutt, Petone and Kapiti."
  },
  {
    q: "Do you replace old or obsolete joinery hardware?",
    a: "Yes. Where possible we source compatible older hardware, including handles, locks, rollers and wedges for aluminium joinery that is no longer current."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a
    }
  }))
};
---

<Layout title={title} description={description} canonical={canonical} schema={[faqSchema]}>
  <Breadcrumbs />

  <main class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="text-3xl font-extrabold">Aluminium Joinery Repairs</h1>
    <p class="mt-4 text-slate-300">This is the broad repair page for single and double glazed aluminium joinery across Wellington. If the job involves a window or door that is worn, loose, leaking, not locking, not sliding, not staying open or generally not operating as it should, it usually lands here.</p>

    <section class="mt-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">Common issues</h2>
        <p class="mt-2 text-sm text-slate-300">Loose handles, failed locks, bent stays, noisy hinges, worn rollers, failed wedges, rattling sashes, dropped doors and leaking aluminium joinery.</p>
      </div>
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">What we do</h2>
        <p class="mt-2 text-sm text-slate-300">We diagnose the failed part, source compatible hardware, realign the joinery and repair the actual fault before anyone starts talking about full replacement.</p>
      </div>
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">What happens next</h2>
        <p class="mt-2 text-sm text-slate-300">Send a photo, suburb and short description. We will usually identify the likely repair path and point you to the right booking slot quickly.</p>
      </div>
    </section>

    <section class="mt-8 rounded-2xl bg-[var(--brand-surface)] p-6 ring-1 ring-white/10">
      <h2 class="text-2xl font-bold">Searches we commonly help with</h2>
      <p class="mt-3 text-slate-300">People usually find this page while searching aluminium joinery repairs, aluminium window repairs, aluminium door repairs, window handle replacement, door handle replacement, window lock repair, Yale window lock repair, ranchslider repairs, awning stay replacement and leaking aluminium windows. It is the catch-all repair page for aluminium joinery that still deserves repair rather than replacement.</p>
      <div class="mt-4 flex flex-wrap gap-3 text-sm">
        <a class="rounded-full border border-white/10 px-3 py-2 text-slate-200 hover:border-amber-400 hover:text-amber-300" href="/services/window-repairs/">Aluminium window repairs</a>
        <a class="rounded-full border border-white/10 px-3 py-2 text-slate-200 hover:border-amber-400 hover:text-amber-300" href="/services/sliding-door-repairs/">Sliding door repairs</a>
        <a class="rounded-full border border-white/10 px-3 py-2 text-slate-200 hover:border-amber-400 hover:text-amber-300" href="/services/hardware-wedge-replacement/">Handles, locks and wedges</a>
        <a class="rounded-full border border-white/10 px-3 py-2 text-slate-200 hover:border-amber-400 hover:text-amber-300" href="/services/mitre-reseal/">Mitre and sill reseals</a>
      </div>
    </section>

    <QuoteInline
      title="Get a quote for aluminium joinery repairs"
      subtitle="Best for aluminium windows and doors with failed hardware, poor sealing, sticking operation, dropped panels or worn components."
      buttonLabel="Get my joinery quote"
      source="joinery_repairs_page"
    />

    <section class="mt-10 space-y-4">
      <h2 class="text-2xl font-bold">What we repair most often</h2>
      <ul class="list-disc space-y-2 pl-5 text-slate-300">
        <li>Aluminium window handles, door handles, catches and latches</li>
        <li>Window locks, Yale window locks, cylinders and sliding door locksets</li>
        <li>Awning stays, hinges, restrictors and security stays</li>
        <li>Sliding door rollers, tracks and alignment faults</li>
        <li>Wedges, seals, sash fitment and early-stage draught or leak faults</li>
        <li>Older or obsolete joinery hardware that still needs to be kept going</li>
      </ul>
    </section>

    <section class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Where we work</h2>
      <p class="text-slate-300">We book aluminium joinery repairs across <a class="text-amber-400 underline" href="/areas/central-wellington/">Central Wellington</a>, <a class="text-amber-400 underline" href="/areas/porirua/">Porirua</a>, <a class="text-amber-400 underline" href="/areas/lower-hutt/">Lower Hutt</a>, <a class="text-amber-400 underline" href="/areas/upper-hutt/">Upper Hutt</a>, <a class="text-amber-400 underline" href="/areas/petone/">Petone</a> and <a class="text-amber-400 underline" href="/areas/kapiti/">Kapiti</a>.</p>
      <p class="text-slate-300">Related repair pages: <a class="text-amber-400 underline" href="/services/window-repairs/">Window repairs</a> • <a class="text-amber-400 underline" href="/services/sliding-door-repairs/">Sliding door repairs</a> • <a class="text-amber-400 underline" href="/services/lock-picking/">Lock picking</a> • <a class="text-amber-400 underline" href="/leaks/">Draught and leak repairs</a></p>
    </section>

    <section class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Helpful guides</h2>
      <ul class="list-disc space-y-2 pl-5 text-slate-300">
        <li><a class="text-amber-400 underline" href="/blog/sliding-door-repair-costs-wellington/">Sliding door repair costs in Wellington</a></li>
        <li><a class="text-amber-400 underline" href="/blog/window-stays-replacement-guide/">Do your window stays need replacing?</a></li>
        <li><a class="text-amber-400 underline" href="/blog/digital-locks-wellington-elok-yale-ydm-doric-de10/">Digital locks in Wellington: Elock, Yale YDM and Doric DE10</a></li>
      </ul>
    </section>
  </main>

  <FAQ heading="Joinery repair FAQs" items={faqItems} />
</Layout>
