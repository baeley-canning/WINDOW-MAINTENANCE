---
import Layout from "../../layouts/WMBase.astro"; import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Picture from "../../components/Picture.astro"; import QuoteInline from "../../components/QuoteInline.astro";
const title = "Hardware & Wedge Replacement | Wellington aluminium windows"; const description = "Window handles, door handles and window locks (including Yale window handles/locks), plus wedges/seals fitted across Wellington and the Hutt Valley."; const canonical = "https://windowmaintenance.co.nz/services/hardware-wedge-replacement/";
const faqItems = [
  { q: "Do you match finishes for existing joinery?", a: "Yes. We carry common finishes and source compatible handles, locks and wedges to suit your aluminium frames." },
  { q: "Do you replace Yale window handles and Yale window locks?", a: "Yes. We source and fit Yale window handles/locks and compatible equivalents where needed." },
  { q: "Can you supply safety stays and restrictors?", a: "Yes. We fit safety stays/restrictors along with locks and wedges to improve security and sealing." }
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---
<Layout title={title} description={description} canonical={canonical} schema={[faqSchema]}>
  <Breadcrumbs />
  <main class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="text-3xl font-extrabold">Hardware & Wedge Replacement</h1>
    <p class="mt-4 text-slate-300">Supply and fit window handles, door handles, window locks (including Yale window handle/lock replacements), restrictors, safety stays and rubber wedges/seals for single and double-glazed aluminium windows and doors across Wellington, Porirua, Lower Hutt, Upper Hutt, Petone and Kāpiti.</p>
    <section class="mt-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">Common issues</h2>
        <p class="mt-2 text-sm text-slate-300">Loose window handles, worn door handles, failed Yale locks, broken catches, perished wedges and windows that no longer close tightly.</p>
      </div>
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">What we do</h2>
        <p class="mt-2 text-sm text-slate-300">Match compatible hardware, replace wedges and seals, fit restrictors and restore proper locking and sealing without unnecessary replacement joinery.</p>
      </div>
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">What happens next</h2>
        <p class="mt-2 text-sm text-slate-300">Send a photo of the handle, lock or wedge if you have one. We’ll usually identify the likely part before booking.</p>
      </div>
    </section>
    <QuoteInline
      title="Get a quote for hardware, locks & wedges"
      subtitle="Best for Yale window handles, window locks, door handles, restrictors, catches, wedges and seals."
      buttonLabel="Get my hardware quote"
      source="hardware_page"
    />
    <h2 class="mt-10 text-2xl font-bold">Common parts we replace</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">

    <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
      <div class="ratio-4-3 card-frame">
        <Picture base="euro-lock-cylinder" alt="Euro lock cylinder for aluminium doors" className="h-full w-full object-contain bg-white/5 p-2" />
      </div>
    </figure>
    <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
      <div class="ratio-4-3 card-frame">
        <img src="/img/yale-window-handles.webp" alt="Yale window handles for aluminium joinery" class="h-full w-full object-contain bg-white/5 p-2" loading="lazy" decoding="async" />
      </div>
    </figure>
    <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
      <div class="ratio-4-3 card-frame">
        <Picture base="sash-handles" alt="Aluminium sash window handles" className="h-full w-full object-contain bg-white/5 p-2" />
      </div>
    </figure>
    <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
      <div class="ratio-4-3 card-frame">
        <img src="/img/sliding-window-lock.webp" alt="Sliding window lock for aluminium windows" class="h-full w-full object-contain bg-white/5 p-2" loading="lazy" decoding="async" />
      </div>
    </figure>
    <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
      <div class="ratio-4-3 card-frame">
        <Picture base="glazing-wedge" alt="Glazing wedge and rubber seal profiles" className="h-full w-full object-contain bg-white/5 p-2" />
      </div>
    </figure>
    </div>
    <div class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Where we work</h2>
      <p class="text-slate-300">Wellington, Porirua, Lower Hutt, Upper Hutt, Petone and Kāpiti.</p>
      <p class="text-slate-300">Related: <a class="text-amber-400 underline" href="/services/window-repairs/">Window repairs</a> • <a class="text-amber-400 underline" href="/security/">Security stays</a> • <a class="text-amber-400 underline" href="/services/lock-picking/">Lock picking</a></p>
    </div>
    <div class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Hardware & wedges FAQs</h2>
      <ul class="list-disc space-y-2 pl-5 text-slate-300">
        {faqItems.map(item => <li><strong>{item.q}</strong><br />{item.a}</li>)}
      </ul>
    </div>
    <div class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Helpful guides</h2>
      <ul class="list-disc space-y-2 pl-5 text-slate-300">
        <li><a class="text-amber-400 underline" href="/blog/digital-locks-wellington-elok-yale-ydm-doric-de10/">Digital locks in Wellington: Elock, Yale YDM and Doric DE10</a></li>
        <li><a class="text-amber-400 underline" href="/blog/sliding-door-sticking/">Fix a sticking sliding door</a></li>
        <li><a class="text-amber-400 underline" href="/blog/draft-proofing-wellington/">Draft-proofing aluminium windows in Wellington</a></li>
      </ul>
    </div>
  </main>
</Layout>
