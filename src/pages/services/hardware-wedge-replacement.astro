---
import Layout from "../../layouts/WMBase.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Picture from "../../components/Picture.astro";
import QuoteInline from "../../components/QuoteInline.astro";
import FAQ from "../../components/FAQ.astro";

const title = "Window Handles, Door Handles & Yale Locks Wellington";
const description = "Window handles, door handles, Yale window locks, wedges, restrictors and aluminium joinery hardware replaced across Wellington, Porirua and the Hutt Valley.";
const canonical = "https://windowmaintenance.co.nz/services/hardware-wedge-replacement/";

const faqItems = [
  {
    q: "Do you replace Yale window handles and Yale window locks?",
    a: "Yes. We replace Yale window handles, Yale window locks and compatible aluminium joinery hardware where the original part is worn or broken."
  },
  {
    q: "What are glazing wedges and do you replace them?",
    a: "Glazing wedges are the rubber sealing profiles that help secure and weather-seal the glass in aluminium joinery. We replace hardened, shrunken or damaged wedges where needed."
  },
  {
    q: "Can you source older or obsolete hardware?",
    a: "Yes. We regularly identify and source older handles, catches, locksets and compatible replacements for aluminium windows and doors."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a
    }
  }))
};
---

<Layout title={title} description={description} canonical={canonical} schema={[faqSchema]}>
  <Breadcrumbs />

  <main class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="text-3xl font-extrabold">Hardware, Handles, Locks & Wedge Replacement</h1>
    <p class="mt-4 text-slate-300">This page is for aluminium joinery hardware repairs and replacements across Wellington. That includes window handles, door handles, window locks, Yale window handles, Yale window locks, catches, cylinders, restrictors, safety stays and glazing wedges or seals.</p>

    <section class="mt-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">Common issues</h2>
        <p class="mt-2 text-sm text-slate-300">Loose handles, snapped catches, failed window locks, sticky Yale hardware, worn cylinders, tired wedges and windows or doors that no longer close tightly.</p>
      </div>
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">What we do</h2>
        <p class="mt-2 text-sm text-slate-300">We identify the hardware, source the right part, fit it cleanly and restore proper closure, security and weather sealing without unnecessary replacement joinery.</p>
      </div>
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">What happens next</h2>
        <p class="mt-2 text-sm text-slate-300">If you can send a photo of the broken handle, lock or wedge, do it. That usually shortens the identification and quoting process considerably.</p>
      </div>
    </section>

    <section class="mt-8 rounded-2xl bg-[var(--brand-surface)] p-6 ring-1 ring-white/10">
      <h2 class="text-2xl font-bold">Searches we commonly help with</h2>
      <p class="mt-3 text-slate-300">People usually land here from searches like window handle replacement, door handle repair, window lock repair, Yale window handle, Yale window lock, sliding door handle repair, aluminium window hardware replacement, glazing wedge replacement and restrictor fitting. This page is built to pick up that whole hardware-and-sealing cluster.</p>
      <div class="mt-4 flex flex-wrap gap-3 text-sm">
        <a class="rounded-full border border-white/10 px-3 py-2 text-slate-200 hover:border-amber-400 hover:text-amber-300" href="/services/window-repairs/">Window repairs</a>
        <a class="rounded-full border border-white/10 px-3 py-2 text-slate-200 hover:border-amber-400 hover:text-amber-300" href="/services/sliding-door-repairs/">Sliding door repairs</a>
        <a class="rounded-full border border-white/10 px-3 py-2 text-slate-200 hover:border-amber-400 hover:text-amber-300" href="/services/lock-picking/">Lock picking and cylinders</a>
      </div>
    </section>

    <QuoteInline
      title="Get a quote for handles, locks or wedges"
      subtitle="Best for broken window handles, door handles, Yale locks, catches, restrictors, worn cylinders and glazing wedge replacement."
      buttonLabel="Get my hardware quote"
      source="hardware_page"
    />

    <section class="mt-10">
      <h2 class="text-2xl font-bold">Common parts we replace</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
          <div class="ratio-4-3 card-frame">
            <img src="/img/yale-window-handles.webp" alt="Yale window handles for aluminium joinery" class="h-full w-full object-contain bg-white/5 p-2" loading="lazy" decoding="async" />
          </div>
        </figure>
        <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
          <div class="ratio-4-3 card-frame">
            <Picture base="sash-handles" alt="Aluminium sash window handles" className="h-full w-full object-contain bg-white/5 p-2" />
          </div>
        </figure>
        <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
          <div class="ratio-4-3 card-frame">
            <Picture base="euro-lock-cylinder" alt="Euro lock cylinder for aluminium doors" className="h-full w-full object-contain bg-white/5 p-2" />
          </div>
        </figure>
        <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
          <div class="ratio-4-3 card-frame">
            <Picture base="glazing-wedge" alt="Glazing wedge and seal profile for aluminium joinery" className="h-full w-full object-contain bg-white/5 p-2" />
          </div>
        </figure>
      </div>
    </section>

    <section class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Where we work</h2>
      <p class="text-slate-300">We fit hardware and wedges across <a class="text-amber-400 underline" href="/areas/central-wellington/">Central Wellington</a>, <a class="text-amber-400 underline" href="/areas/porirua/">Porirua</a>, <a class="text-amber-400 underline" href="/areas/lower-hutt/">Lower Hutt</a>, <a class="text-amber-400 underline" href="/areas/upper-hutt/">Upper Hutt</a>, <a class="text-amber-400 underline" href="/areas/petone/">Petone</a> and <a class="text-amber-400 underline" href="/areas/kapiti/">Kapiti</a>.</p>
      <p class="text-slate-300">Related pages: <a class="text-amber-400 underline" href="/services/window-repairs/">Window repairs</a> • <a class="text-amber-400 underline" href="/services/joinery-repairs/">Aluminium joinery repairs</a> • <a class="text-amber-400 underline" href="/services/lock-picking/">Lock picking</a></p>
    </section>

    <section class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Helpful guides</h2>
      <ul class="list-disc space-y-2 pl-5 text-slate-300">
        <li><a class="text-amber-400 underline" href="/blog/digital-locks-wellington-elok-yale-ydm-doric-de10/">Digital locks in Wellington: Elock, Yale YDM and Doric DE10</a></li>
        <li><a class="text-amber-400 underline" href="/blog/inframe-security-stays-wellington/">In-frame security stays vs face-mounted stays</a></li>
        <li><a class="text-amber-400 underline" href="/blog/sliding-door-sticking/">Fix a sticking sliding door</a></li>
      </ul>
    </section>
  </main>

  <FAQ heading="Hardware and wedge FAQs" items={faqItems} />
</Layout>
