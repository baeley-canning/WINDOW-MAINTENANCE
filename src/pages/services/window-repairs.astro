---
import Layout from "../../layouts/WMBase.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Picture from "../../components/Picture.astro";
import QuoteInline from "../../components/QuoteInline.astro";

const title = "Aluminium Window Repairs Wellington | Handles, Hinges & Drafts";
const description = "Single and double-glazed aluminium window repairs: stays, hinges, window handles, Yale locks, latches and draft fixes across Wellington, Porirua and the Hutt Valley.";
const canonical = "https://windowmaintenance.co.nz/services/window-repairs/";

const faqItems = [
  { q: "Do you repair single and double glazed aluminium windows?", a: "Yes. We work on both single- and double-glazed aluminium windows, including stays, hinges, seals and alignment." },
  { q: "Do you replace stays and hinges in coastal areas?", a: "Yes. We carry corrosion-resistant hardware and fit stays/hinges suited to Wellington and Porirua coastal conditions." },
  { q: "Can you fix drafts in older aluminium windows?", a: "We replace wedges/seals, service latches and re-align sashes to stop rattles and drafts." }
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---
<Layout title={title} description={description} canonical={canonical} schema={[faqSchema]}>
  <Breadcrumbs />
  <main class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="text-3xl font-extrabold">Aluminium Window Repairs</h1>
    <p class="mt-4 text-slate-300">Single and double-glazed aluminium window repairs: stays, hinges, window handles, Yale window locks, latches and latch alignment, plus draft and rattle fixes across Wellington, Porirua, Lower Hutt, Upper Hutt, Petone and Kāpiti.</p>
    <section class="mt-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">Common issues</h2>
        <p class="mt-2 text-sm text-slate-300">Bent awning stays, worn hinges, loose sash handles, failed Yale window locks and windows that no longer hold position.</p>
      </div>
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">What we do</h2>
        <p class="mt-2 text-sm text-slate-300">Match hardware, re-align sashes, replace broken parts, service locks and stop drafts/rattles without pushing you toward full replacement.</p>
      </div>
      <div class="rounded-xl bg-[var(--brand-surface)] p-5 ring-1 ring-white/10">
        <h2 class="text-lg font-bold">What happens next</h2>
        <p class="mt-2 text-sm text-slate-300">Send the suburb and issue. We will usually reply the same day with likely parts, pricing guidance and next available booking.</p>
      </div>
    </section>
    <QuoteInline
      title="Get a quote for window repairs"
      subtitle="Best for sticking awning windows, bent stays, failed Yale window locks, worn sash handles and rattling single- or double-glazed joinery."
      buttonLabel="Get my window repair quote"
      source="window_repairs_page"
    />
    <h2 class="mt-10 text-2xl font-bold">Common parts we replace</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">

    <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
      <div class="ratio-4-3 card-frame">
        <Picture base="hinge" alt="Aluminium window hinge replacement" className="h-full w-full object-cover" />
      </div>
    </figure>
    <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
      <div class="ratio-4-3 card-frame">
        <Picture base="security-stays" alt="Window security stays / restrictors" className="h-full w-full object-cover" />
      </div>
    </figure>
    <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
      <div class="ratio-4-3 card-frame">
        <Picture base="sash-handles" alt="Aluminium sash window handles" className="h-full w-full object-cover" />
      </div>
    </figure>
    <figure class="rounded-xl bg-[var(--brand-surface)] p-4 ring-1 ring-white/10">
      <div class="ratio-4-3 card-frame">
        <Picture base="glazing-wedge" alt="Glazing wedge and rubber seal profile for aluminium window" className="h-full w-full object-cover" />
      </div>
    </figure>
    </div>
    <div class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Where we work</h2>
      <p class="text-slate-300">Wellington, Porirua, Lower Hutt, Upper Hutt, Petone and Kāpiti.</p>
      <p class="text-slate-300">Related: <a class="text-amber-400 underline" href="/stays/">Awning stays &amp; hinges</a> • <a class="text-amber-400 underline" href="/leaks/">Draught &amp; leak repairs</a></p>
    </div>
    <div class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Window repair FAQs</h2>
      <ul class="list-disc space-y-2 pl-5 text-slate-300">
        {faqItems.map(item => <li><strong>{item.q}</strong><br />{item.a}</li>)}
      </ul>
    </div>
    <div class="mt-8 space-y-3">
      <h2 class="text-2xl font-bold">Helpful guides</h2>
      <ul class="list-disc space-y-2 pl-5 text-slate-300">
        <li><a class="text-amber-400 underline" href="/blog/draft-proofing-wellington/">Draft-proofing aluminium windows in Wellington</a></li>
        <li><a class="text-amber-400 underline" href="/blog/window-stays-replacement-guide/">Do your window stays need replacing?</a></li>
        <li><a class="text-amber-400 underline" href="/blog/awning-stay-repair-storm/">Awning stay replacement after a storm</a></li>
        <li><a class="text-amber-400 underline" href="/blog/inframe-security-stays-wellington/">In-frame security stays vs face-mounted stays</a></li>
      </ul>
    </div>
  </main>
</Layout>
